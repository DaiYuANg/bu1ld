{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "bu1ld",
  "scopeName": "source.bu1ld",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#rules"
    },
    {
      "include": "#fields"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.bu1ld",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.bu1ld",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.bu1ld",
              "match": "\\\\(?:[\"\\\\/bfnrt]|u[0-9a-fA-F]{4})"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.import.bu1ld",
          "match": "\\bimport\\b"
        },
        {
          "name": "keyword.declaration.bu1ld",
          "match": "\\b(?:workspace|plugin|toolchain|task|run)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.bu1ld",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "constant.language.plugin-source.bu1ld",
          "match": "\\b(?:builtin|local|global)\\b"
        },
        {
          "name": "constant.language.platform.bu1ld",
          "match": "\\b(?:os|arch)\\b"
        }
      ]
    },
    "rules": {
      "patterns": [
        {
          "name": "entity.name.function.rule.bu1ld",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\.[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "fields": {
      "patterns": [
        {
          "name": "variable.other.member.field.bu1ld",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*=)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.bu1ld",
          "match": "\\b(?:env|exec|shell)\\b(?=\\s*\\()"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.bu1ld",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.bu1ld",
          "match": "\\$\\(|[+\\-*/=]"
        }
      ]
    }
  }
}
