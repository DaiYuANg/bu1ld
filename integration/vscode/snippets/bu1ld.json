{
  "workspace": {
    "prefix": "workspace",
    "body": [
      "workspace {",
      "  name = \"${1:name}\"",
      "  default = ${2:build}",
      "}"
    ],
    "description": "Declare a bu1ld workspace"
  },
  "builtin plugin": {
    "prefix": "plugin-builtin",
    "body": [
      "plugin ${1:archive} {",
      "  source = builtin",
      "  id = \"builtin.${1:archive}\"",
      "}"
    ],
    "description": "Declare a builtin plugin"
  },
  "go plugin": {
    "prefix": "plugin-go",
    "body": [
      "plugin go {",
      "  source = local",
      "  id = \"org.bu1ld.go\"",
      "  version = \"${1:0.1.0}\"",
      "}"
    ],
    "description": "Declare the external Go plugin"
  },
  "java plugin": {
    "prefix": "plugin-java",
    "body": [
      "plugin java {",
      "  source = local",
      "  id = \"org.bu1ld.java\"",
      "  version = \"${1:0.1.0}\"",
      "}"
    ],
    "description": "Declare the external Java plugin"
  },
  "task": {
    "prefix": "task",
    "body": [
      "task ${1:name} {",
      "  deps = [${2}]",
      "  inputs = [${3}]",
      "  outputs = [${4}]",
      "  run {",
      "    ${5:exec(\"command\")}",
      "  }",
      "}"
    ],
    "description": "Declare a custom task"
  },
  "go binary": {
    "prefix": "go-binary",
    "body": [
      "go.binary ${1:build} {",
      "  deps = [${2}]",
      "  main = \"${3:./cmd/cli}\"",
      "  out = \"${4:dist/bu1ld}\"",
      "}"
    ],
    "description": "Declare a Go binary rule"
  },
  "go test": {
    "prefix": "go-test",
    "body": [
      "go.test ${1:test} {",
      "  packages = [\"${2:./...}\"]",
      "}"
    ],
    "description": "Declare a Go test rule"
  },
  "java config": {
    "prefix": "java-config",
    "body": [
      "java {",
      "  name = \"${1:app}\"",
      "  release = \"${2:17}\"",
      "}"
    ],
    "description": "Configure the external Java plugin"
  },
  "java compile": {
    "prefix": "java-compile",
    "body": [
      "java.compile ${1:compileGenerated} {",
      "  srcs = [\"${2:generated/**/*.java}\"]",
      "  out = \"${3:build/classes/java/generated}\"",
      "}"
    ],
    "description": "Declare a native Java compile rule"
  },
  "java jar": {
    "prefix": "java-jar",
    "body": [
      "java.jar ${1:package} {",
      "  deps = [${2:compileJava}]",
      "  classes = \"${3:build/classes/java/main}\"",
      "  out = \"${4:build/libs/app.jar}\"",
      "}"
    ],
    "description": "Declare a native Java jar rule"
  },
  "docker image": {
    "prefix": "docker-image",
    "body": [
      "docker.image ${1:image} {",
      "  context = \"${2:.}\"",
      "  dockerfile = \"${3:Dockerfile}\"",
      "  tags = [\"${4:example/app:dev}\"]",
      "  load = ${5:true}",
      "}"
    ],
    "description": "Declare a Docker image rule"
  },
  "archive zip": {
    "prefix": "archive-zip",
    "body": [
      "archive.zip ${1:package_zip} {",
      "  deps = [${2:build}]",
      "  srcs = [\"${3:dist/**}\"]",
      "  out = \"${4:dist/package.zip}\"",
      "}"
    ],
    "description": "Declare a zip archive rule"
  },
  "archive tar": {
    "prefix": "archive-tar",
    "body": [
      "archive.tar ${1:package_tgz} {",
      "  deps = [${2:build}]",
      "  srcs = [\"${3:dist/**}\"]",
      "  out = \"${4:dist/package.tar.gz}\"",
      "  gzip = ${5:true}",
      "}"
    ],
    "description": "Declare a tar archive rule"
  }
}
