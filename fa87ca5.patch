+
+interface CompilerProject {
+  fileNames: string[];
+  options: ts.CompilerOptions;
+  relativeOutDir: string;
+}
+
+function loadCompilerProject(workDir: string, params: Record<string, unknown>, noEmit: boolean): CompilerProject {
