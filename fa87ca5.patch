+  return {
+    fileNames: uniqueSorted(fileNames.map((file) => path.resolve(file))),
+    options,
+    relativeOutDir,
+  };
+}
+
+function compilerOptionsFromParams(root: string, params: Record<string, unknown>, hasConfig: boolean): ts.CompilerOptions {
