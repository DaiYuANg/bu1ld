+    return { command: executable, args };
+  }
+  const commandParts = windowsCommandParts(executable, args);
+  return {
+    command: process.env.ComSpec ?? "cmd.exe",
+    args: ["/d", "/s", "/c", quoteWindowsCommand(commandParts)],
