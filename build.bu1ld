workspace {
  name = "bu1ld"
  default = build
}

plugin go {
  source = builtin
  id = "builtin.go"
}

toolchain go {
  version = env("GO_VERSION", "1.26.2")
  settings = { mode = "module", platform = os + "/" + arch }
}

task prepare {
  inputs = []
  outputs = ["dist"]
  command = ["mkdir", "-p", "dist"]
}

import "tasks/go.bu1ld"
