<configuration>
  <property name="PLUGIN_LOG_DIR" value="${BU1LD_PLUGIN_LOG_DIR:-.bu1ld/logs}" />

  <appender name="stderr" class="ch.qos.logback.core.ConsoleAppender">
    <target>System.err</target>
    <encoder>
      <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%thread] %logger{40} - %msg%n</pattern>
    </encoder>
  </appender>

  <appender name="file" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${PLUGIN_LOG_DIR}/java-plugin.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${PLUGIN_LOG_DIR}/java-plugin.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
      <maxFileSize>10MB</maxFileSize>
      <maxHistory>14</maxHistory>
      <totalSizeCap>128MB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%thread] %logger{48} - %msg%n</pattern>
    </encoder>
  </appender>

  <logger name="org.bu1ld.plugins.java" level="${BU1LD_PLUGIN_LOG_LEVEL:-INFO}" />

  <root level="WARN">
    <appender-ref ref="stderr" />
    <appender-ref ref="file" />
  </root>
</configuration>
